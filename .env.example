# Stripe (optional legacy single-key — prefer DB connections via /integrations/stripe)
STRIPE_SECRET_KEY=

# QuickBooks Online (OAuth — no API key)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
APP_URL=http://localhost:5174

# Auth & encryption (required for login and stored integration secrets)
SESSION_SECRET=
ENCRYPTION_KEY=

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lotus_ledger

# First user (npm run db:seed) — not sent by email
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=

# Resend (invite emails)
RESEND_API_KEY=
RESEND_FROM=Lotus Ledger <you@yourdomain.com>
# FROM_EMAIL=...  # alias for RESEND_FROM if you prefer that name
