  "dependencies": {
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "intuit-oauth": "^4.2.3",
    "isbot": "^5.1.36",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1"
